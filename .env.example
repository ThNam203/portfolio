# Public site URL (no trailing slash). Used for canonical, OG, sitemap.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Resend — used by /api/contact
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_FROM_EMAIL=portfolio@your-verified-domain.com
CONTACT_TO_EMAIL=hthnam203@gmail.com

# Optional. Increases GitHub API rate limit from 60 → 5000 per hour.
# Use a fine-grained read-only token. NOT required for the site to work.
GITHUB_TOKEN=
